# RotDash — Environment Variables
# Copy this file to .env and fill in your values.

# MongoDB
# Local Docker: mongodb://localhost:27017/rotdash
# MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/rotdash
MONGODB_URI=mongodb://localhost:27017/rotdash

# App
NEXT_PUBLIC_APP_NAME=RotDash

# Don't set NODE_ENV — Next.js sets it automatically (development for dev, production for build)
