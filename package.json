{
  "name": "rotdash",
  "version": "0.1.0",
  "private": false,
  "scripts": {
    "dev": "bun --bun next dev",
    "build": "bun --bun next build",
    "start": "bun --bun .next/standalone/server.js",
    "lint": "eslint .",
    "docker:up": "docker rm -f rotdash-app 2>/dev/null; docker build -t rotdash . && docker run -d --name rotdash-app -p 3000:3000 -e MONGODB_URI=${MONGODB_URI:-mongodb://host.docker.internal:27017/rotdash} rotdash",
    "docker:down": "docker rm -f rotdash-app 2>/dev/null || true"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^20.19.37",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@tailwindcss/postcss": "^4.2.1",
    "tailwindcss": "^4.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
